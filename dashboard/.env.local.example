# ============================================================
# Personal AI OS — Dashboard env vars
# Copy to .env.local for local dev, or set in Vercel dashboard.
# ============================================================

# ── REQUIRED ────────────────────────────────────────────────

# Same Supabase connection string as the backend
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# ── GOOGLE CALENDAR ─────────────────────────────────────────
#
# Option A — for production (Vercel):
#   Paste the raw JSON content of each credential file as a single-line
#   string in the Vercel environment variables panel.
#
#   GOOGLE_CREDENTIALS_JSON={"installed":{"client_id":"...","client_secret":"...","redirect_uris":[...]}}
#   GOOGLE_TOKEN_JSON={"access_token":"...","refresh_token":"...","scope":"...","token_type":"Bearer","expiry_date":...}
#
# Option B — for local development:
#
GOOGLE_CREDENTIALS_PATH=/absolute/path/to/google-oauth.json
GOOGLE_TOKEN_PATH=/absolute/path/to/google-token.json
#
# If neither option is configured, the Calendar section on the Today page
# is simply hidden (empty array returned — no crash).
