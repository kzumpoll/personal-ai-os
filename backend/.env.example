# ============================================================
# Personal AI OS — Backend env vars
# Copy to .env and fill in real values.
# ============================================================

# ── REQUIRED ────────────────────────────────────────────────

# Supabase PostgreSQL connection string
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Anthropic Claude API key
ANTHROPIC_API_KEY=

# ── OPTIONAL ────────────────────────────────────────────────

# OpenAI key — only needed if voice transcription (Whisper) is used
OPENAI_API_KEY=

# Node environment — set to "production" on Railway
NODE_ENV=development

# Port the HTTP server listens on — Railway sets this automatically
PORT=3001

# ── GOOGLE CALENDAR ─────────────────────────────────────────
#
# Option A — for production (Railway):
#   Set GOOGLE_CREDENTIALS_JSON and GOOGLE_TOKEN_JSON to the raw
#   JSON content of each file. Get these values from your local
#   credentials/ directory after running google-auth.ts once.
#
#   GOOGLE_CREDENTIALS_JSON={"installed":{"client_id":"...","client_secret":"...","redirect_uris":["urn:ietf:wg:oauth:2.0:oob","http://localhost"]}}
#   GOOGLE_TOKEN_JSON={"access_token":"...","refresh_token":"...","scope":"...","token_type":"Bearer","expiry_date":...}
#
# Option B — for local development (file paths):
#   Run `npx tsx src/scripts/google-auth.ts` to generate the token,
#   then point these vars at the generated files.
#
GOOGLE_CREDENTIALS_PATH=./credentials/google-oauth.json
GOOGLE_TOKEN_PATH=./credentials/google-token.json
#
# If neither option is configured, Calendar features are silently disabled.
